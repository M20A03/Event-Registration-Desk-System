<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= eventName %></title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <canvas class="hyper-scene" data-hyper-scene aria-hidden="true"></canvas>
    <main class="page-shell">
      <section class="registration-panel success-panel">
        <div class="event-kicker">Confirmed</div>
        <h1>Thank you, <%= registration.fullName %>.</h1>
        <p class="lede">Your registration for <%= eventName %> is complete. A confirmation email with a calendar file has been sent to <%= registration.email %>.</p>

        <% if (locals.alreadyRegistered) { %>
          <div class="alert note-alert" role="alert">
            <p>Note: This student was already registered. Displaying their existing details.</p>
          </div>
        <% } %>

        <dl class="details">
          <div>
            <dt>Registration ID</dt>
            <dd><%= registration.registrationId %></dd>
          </div>
          <div>
            <dt>University / College</dt>
            <dd><%= registration.studentOrigin || 'Not provided' %></dd>
          </div>
          <div>
            <dt>Register No.</dt>
            <dd><%= registration.registerNo || 'Not applicable' %></dd>
          </div>
          <div>
            <dt>College Name</dt>
            <dd><%= registration.collegeName || 'Not applicable' %></dd>
          </div>
          <div>
            <dt>Ticket Type</dt>
            <dd><%= registration.ticketType %></dd>
          </div>
          <div>
            <dt>Events</dt>
            <dd><%= registration.participatingEvents && registration.participatingEvents.length ? registration.participatingEvents.join(', ') : 'Not selected' %></dd>
          </div>
          <div>
            <dt>Email</dt>
            <dd><%= registration.email %></dd>
          </div>
          <div>
            <dt>Phone</dt>
            <dd><%= registration.phone || 'Not provided' %></dd>
          </div>
        </dl>

        <div class="wifi-card">
          <h3>Venue WiFi Access</h3>
          <p>Share these connection credentials with the attendee:</p>
          <div class="wifi-grid">
            <div>
              <span>Network Name (SSID)</span>
              <strong><%= event.wifiSsid %></strong>
            </div>
            <div>
              <span>Password</span>
              <strong><%= event.wifiPassword %></strong>
            </div>
          </div>
        </div>

        <a class="button-link" href="/register">Register another attendee</a>
      </section>
    </main>
    <script src="/js/hyper-scene.js"></script>
  </body>
</html>
