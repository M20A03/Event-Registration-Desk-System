<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= eventName %></title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <canvas class="hyper-scene" data-hyper-scene aria-hidden="true"></canvas>
    <main class="page-shell">
      <section class="registration-panel">
        <div class="event-kicker">Event Registration</div>
        <h1><%= eventName %></h1>
        <p class="lede">Reserve your seat and receive an automatic email confirmation with a calendar invite.</p>
        <div class="event-summary" aria-label="Event highlights">
          <span>Student Desk</span>
          <span>Christ University</span>
          <span>Guest Colleges</span>
        </div>

        <% if (errors.length) { %>
          <div class="alert" role="alert">
            <% errors.forEach((error) => { %>
              <p><%= error.msg %></p>
            <% }) %>
          </div>
        <% } %>

        <form id="registrationForm" class="form" action="/register" method="post" novalidate>
          <div class="field field-wide">
            <label for="fullName">Full Name</label>
            <input id="fullName" name="fullName" type="text" value="<%= formData.fullName || '' %>" required maxlength="120" autocomplete="name" placeholder="Enter attendee name">
          </div>

          <div class="field">
            <label for="email">Email Address</label>
            <input id="email" name="email" type="email" value="<%= formData.email || '' %>" required autocomplete="email" placeholder="name@example.com">
          </div>

          <div class="field">
            <label for="phone">Phone Number <span>(optional)</span></label>
            <input id="phone" name="phone" type="tel" value="<%= formData.phone || '' %>" maxlength="30" autocomplete="tel" placeholder="+91 98765 43210">
          </div>

          <div class="field">
            <label for="studentOrigin">University / College</label>
            <select id="studentOrigin" name="studentOrigin" required>
              <option value="">Select student type</option>
              <option value="Christ University" <%= formData.studentOrigin === 'Christ University' ? 'selected' : '' %>>Christ University</option>
              <option value="Other College" <%= formData.studentOrigin === 'Other College' ? 'selected' : '' %>>Outside Christ University</option>
            </select>
          </div>

          <div class="field">
            <label for="ticketType">Ticket Type</label>
            <select id="ticketType" name="ticketType" required>
              <option value="">Select a ticket</option>
              <% ticketTypes.forEach((ticketType) => { %>
                <option value="<%= ticketType %>" <%= formData.ticketType === ticketType ? 'selected' : '' %>><%= ticketType %></option>
              <% }) %>
            </select>
          </div>

          <div class="field" data-student-field="registerNo">
            <label id="registerNoLabel" for="registerNo">Register No. <span style="color: var(--danger-text);">*</span></label>
            <input id="registerNo" name="registerNo" type="text" value="<%= formData.registerNo || '' %>" maxlength="50" autocomplete="off" placeholder="Christ register number">
          </div>

          <div class="field" data-student-field="collegeName">
            <label id="collegeNameLabel" for="collegeName">College Name <span style="color: var(--danger-text);">*</span></label>
            <input id="collegeName" name="collegeName" type="text" value="<%= formData.collegeName || '' %>" maxlength="160" autocomplete="organization" placeholder="Enter college name">
          </div>

          <p id="clientError" class="client-error" aria-live="polite"></p>
          <button type="submit">Register Now</button>
        </form>
      </section>
    </main>
    <script src="/js/hyper-scene.js"></script>
    <script src="/js/register.js"></script>
  </body>
</html>
